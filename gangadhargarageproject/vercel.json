{
  "version": 2,
  "cleanUrls": true,
  "framework": null,
  "builds": [
    {
      "src": "build/web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "build/web/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "build/web/index.html"
    }
  ]
}
